# ── Google Cloud ─────────────────────────────────────────────────────────────
# Path to your service account JSON key file (download from GCP Console)
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcp/ehs-sa-key.json

GCP_PROJECT_ID=ehs-incident-detection-blissey
GCP_LOCATION=us-central1
GCS_BUCKET_NAME=ehs-video-analysis-2026-pavithran
GCS_VIDEO_PREFIX=videos/

# ── Local dataset (alternative to GCS when running locally) ──────────────────
LOCAL_VIDEOS_DIR=data/videos
LOCAL_GROUND_TRUTH=data/mapping file.xlsx

# ── Model ─────────────────────────────────────────────────────────────────────
# Options: gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-pro
VERTEX_MODEL=gemini-2.5-flash

# ── Pipeline behaviour ────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
STAGE1_VOTES=3
FRAME_FALLBACK_FPS=2.0
FRAME_FALLBACK_MAX_FRAMES=10
SLEEP_BETWEEN_VIDEOS=1.0
RETRY_ATTEMPTS=4

# ── Sampling (leave blank to use model defaults) ──────────────────────────────
TEMPERATURE=0.0
TOP_K=
TOP_P=

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUTS_DIR=outputs
